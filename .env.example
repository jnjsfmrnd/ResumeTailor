# ResumeTailor – local development environment variables
# Copy this file to .env.local and fill in the values.
# The docker-compose.yml uses .env.local for secrets not set inline.
#
# DO NOT commit .env.local to source control.

# Django
DJANGO_SECRET_KEY=replace-with-a-long-random-string
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost 127.0.0.1

# GitHub Models API (get from https://github.com/marketplace/models)
GITHUB_MODELS_API_KEY=

# Azure Storage (only needed to test QA storage path locally)
AZURE_STORAGE_ACCOUNT=
AZURE_STORAGE_KEY=
AZURE_STORAGE_CONTAINER=resumetailor-qa

# Generation / session settings (optional overrides)
RESUME_TAILOR_GENERATION_TIMEOUT=120
RESUME_TAILOR_SESSION_RETENTION_DAYS=7
